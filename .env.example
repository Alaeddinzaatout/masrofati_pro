# Firebase Web SDK config — copy this file to `.env` and fill in real values.
# These are NOT secret in the cryptographic sense (they ship in the client bundle),
# but you should still restrict the API key in Google Cloud Console (HTTP referrers,
# Android package name, iOS bundle id) and lock down Firestore with security rules.
#
# After editing .env you MUST restart Metro: `expo start -c`.
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
