{
  "expo": {
    "name": "مصروفاتي برو",
    "slug": "masrofati-pro",
    "version": "1.0.0",
    "runtimeVersion": { "policy": "appVersion" },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#007acc"
    },
    "ios": {
      "supportsTablet": true,
      "jsEngine": "hermes"
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#007acc"
      },
      "package": "com.alaadden.masrofatipro",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json",
      "jsEngine": "hermes"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "يحتاج التطبيق للوصول إلى الصور لتحليل الفواتير.",
          "cameraPermission": "يحتاج التطبيق للوصول إلى الكاميرا لتصوير الفواتير."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج التطبيق لمعرفة موقعك لحساب المسافة بينك وبين المحلات في رادار الأسعار."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc209fa3-7e58-4bb1-a872-650a6ce0e053"
      }
    },
    "owner": "alaaddenzaatout",
    "updates": {
      "url": "https://u.expo.dev/bc209fa3-7e58-4bb1-a872-650a6ce0e053",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
